# Application
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# Database
DATABASE_URL=postgresql://eduos:eduos@localhost:5432/eduos

# Redis and queues
REDIS_URL=redis://localhost:6379

# Search
